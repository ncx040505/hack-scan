# VulnScanner AI Configuration
# Copy this file to .env and modify as needed

# ============ 数据库配置（必需）============
# API Settings
DEBUG=false

# Database
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vulnscanner
MONGODB_URL=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379/0

# ============ LLM 配置（后备，建议在网页系统设置中配置）============
# 支持 OpenAI API 兼容的服务 (如 OpenAI, Azure, Ollama, vLLM 等)
# 注意：建议在网页 /settings/llm 中配置，支持多个 LLM 动态切换
OPENAI_API_KEY=
OPENAI_BASE_URL=  # 留空使用 OpenAI，或设置自定义端点
LLM_MODEL=
LLM_TEMPERATURE=

# ============ 扫描配置（后备，建议在网页系统设置中配置）============
# 注意：建议在网页 /settings/system 中配置，可动态修改无需重启
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT=3600
RATE_LIMIT_PER_TARGET=10
SCAN_TEMP_DIR=/tmp/shelling_scans

# ============ 安全配置（必需）============
# Security
SECRET_KEY=change-this-to-a-random-string
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
