# VulnScanner AI Configuration
# Copy this file to .env and modify as needed

# API Settings
DEBUG=true

# Database
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vulnscanner
MONGODB_URL=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
# 支持 OpenAI API 兼容的服务 (如 OpenAI, Azure, Ollama, vLLM 等)
OPENAI_API_KEY=sk-d22cf66e84a1d48fe18fa5f950107a745f54a8abb91d9a6cbe8468e94a1bc176
OPENAI_BASE_URL=https://sub2api.qwqa.de/v1  # 留空使用 OpenAI，或设置自定义端点
LLM_MODEL=gpt-5.2
LLM_TEMPERATURE=0.1

# Scanning Configuration
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT=3600
RATE_LIMIT_PER_TARGET=10

# Security
SECRET_KEY=change-this-to-a-random-string
ALLOWED_ORIGINS=["http://0.0.0.0:3000","http://0.0.0.0:5173"]
